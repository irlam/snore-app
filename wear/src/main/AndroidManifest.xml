<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Vibration for nudge -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Keep watch awake when receiving command -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Wearable communication -->
    <uses-feature android:name="android.hardware.type.watch" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SnoreNudgeWear">

        <activity
            android:name=".WatchMainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity="">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Listens for messages from the phone app -->
        <service
            android:name=".WatchMessageListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:pathPrefix="/snore"
                    android:scheme="wear" />
            </intent-filter>
        </service>

    </application>

</manifest>
